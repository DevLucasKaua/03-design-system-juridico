{
  "name": "@lucas/lex-ui",
  "version": "0.1.0",
  "description": "Lex UI — design system para landing pages e produtos de escritórios de advocacia. Tokens versionados, componentes acessíveis, documentado no Storybook.",
  "license": "MIT",
  "type": "module",
  "sideEffects": [
    "**/*.css"
  ],
  "files": [
    "dist",
    "src/tokens"
  ],
  "main": "./dist/lex-ui.js",
  "module": "./dist/lex-ui.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/lex-ui.js"
    },
    "./styles.css": "./dist/lex-ui.css",
    "./tokens.css": "./src/tokens/tokens.css",
    "./theme.css": "./src/tokens/theme.css",
    "./tailwind-preset": {
      "types": "./dist/tokens/tailwind-preset.d.ts",
      "import": "./dist/tokens/tailwind-preset.js"
    }
  },
  "scripts": {
    "prepare": "npm run build",
    "storybook": "storybook dev -p 6006",
    "build-storybook": "storybook build",
    "build": "vite build && tsc -p tsconfig.build.json",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc -p tsconfig.json --noEmit"
  },
  "peerDependencies": {
    "react": "^18.0.0 || ^19.0.0",
    "react-dom": "^18.0.0 || ^19.0.0"
  },
  "devDependencies": {
    "@storybook/addon-a11y": "^10.5.0",
    "@storybook/addon-docs": "^10.5.0",
    "@storybook/react-vite": "^10.5.0",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/node": "^24.0.0",
    "@types/react": "^19.2.0",
    "@types/react-dom": "^19.2.0",
    "@vitejs/plugin-react": "^6.0.3",
    "axe-core": "^4.12.1",
    "jsdom": "^29.0.0",
    "react": "^19.2.0",
    "react-dom": "^19.2.0",
    "storybook": "^10.5.0",
    "typescript": "^5.8.0",
    "vite": "^8.0.0",
    "vitest": "^4.0.0"
  }
}
